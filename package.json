{
  "name": "markmark-cli",
  "version": "0.1.0",
  "description": "Read, highlight, and comment on Markdown files in your browser. Comments save to a sidecar JSON file you can commit, diff, share, or export. Zero dependencies.",
  "type": "module",
  "bin": {
    "markmark": "bin/markmark.js"
  },
  "main": "lib/server.js",
  "files": [
    "bin",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/markmark.js"
  },
  "keywords": [
    "markdown",
    "viewer",
    "comments",
    "annotations",
    "highlight",
    "review",
    "cli",
    "markdown-viewer",
    "review-tool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paperMoose/markmark.git"
  },
  "homepage": "https://github.com/paperMoose/markmark#readme",
  "bugs": {
    "url": "https://github.com/paperMoose/markmark/issues"
  },
  "author": "paperMoose",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
