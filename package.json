{
  "name": "markmark",
  "version": "0.1.0",
  "description": "Read, highlight, and comment on Markdown files in your browser. Comments save to a sidecar JSON file you can commit, diff, share, or export.",
  "type": "module",
  "bin": {
    "markmark": "bin/markmark.js"
  },
  "main": "lib/server.js",
  "files": [
    "bin",
    "lib",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/markmark.js"
  },
  "keywords": [
    "markdown",
    "viewer",
    "comments",
    "annotations",
    "highlight",
    "review"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
